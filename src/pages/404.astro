---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="404">
  <section class="nf">
    <p class="t-meta nf-code">404 — minus one</p>
    <h1 class="t-hero nf-title">빈 자리</h1>
    <p class="t-serif-i nf-line">여긴 비어 있다 — 8시 방향의 사라진 꽃잎처럼.</p>
    <p class="nf-desc t-meta">NO SIGNAL · 찾으시는 페이지가 없습니다</p>
    <nav class="nf-links">
      <a href={`${base}/`} class="t-meta nf-link">← home</a>
      <a href={`${base}/archive`} class="t-meta nf-link">browse the archive →</a>
    </nav>
  </section>
</Base>

<style>
  .nf {
    min-height: 78vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    text-align: center;
    padding: calc(var(--header-h) + var(--space-4)) var(--gutter) var(--space-5);
  }
  .nf-code { color: var(--accent); }
  .nf-title { color: var(--fg); }
  .nf-line { color: var(--muted); font-size: var(--text-lg); max-width: 30ch; }
  .nf-desc { color: var(--faint); margin-top: var(--space-1); }
  .nf-links {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .nf-link:hover { color: var(--fg); }
</style>
