---
import Base from '../layouts/Base.astro';
---

<Base title="Shop">
  <!-- 실제 공식몰은 발매가 없을 때 의도적으로 NO SIGNAL 화면을 띄운다.
       그 문법을 그대로 번역: 비어 있음 자체가 디자인 -->
  <section class="closed">
    <p class="t-xl closed-signal">NO SIGNAL</p>
    <p class="t-meta">drops are unannounced</p>
    <a
      href="https://www.peaceminusone.com"
      target="_blank"
      rel="noopener noreferrer"
      class="t-meta closed-official"
    >official store ↗</a>
  </section>
</Base>

<style>
  .closed {
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .closed-signal {
    letter-spacing: 0.3em;
    color: var(--muted);
    animation: signal-flicker 6s steps(1) infinite;
  }

  /* CRT 대기 화면처럼 아주 가끔, 절제된 깜빡임 */
  @keyframes signal-flicker {
    0%, 91%, 95%, 100% { opacity: 1; }
    92% { opacity: 0.35; }
    93% { opacity: 0.85; }
    94% { opacity: 0.5; }
  }

  .closed-official {
    margin-top: var(--space-3);
    color: var(--faint);
  }

  .closed-official:hover {
    color: var(--fg);
  }

  @media (prefers-reduced-motion: reduce) {
    .closed-signal { animation: none; }
  }
</style>
