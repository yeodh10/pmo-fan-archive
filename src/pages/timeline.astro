---
import fs from 'node:fs';
import Base from '../layouts/Base.astro';
import timeline from '../../data/timeline.json';

// 이미지 폴백: 파일이 없으면 다크 플레이스홀더
const entries = timeline.map((t) => ({
  ...t,
  hasImage: t.image
    ? fs.existsSync(new URL(`../../public/${t.image}`, import.meta.url))
    : false,
}));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Timeline">
  <div class="tl">
    <div class="tl-rule" aria-hidden="true"></div>

    <header class="tl-head">
      <p class="t-meta">timeline</p>
      <h1 class="t-xl">2013 → now</h1>
      <p class="t-serif-i tl-sub">전시에서 아카이브까지</p>
    </header>

    {entries.map((t, i) => (
      <section class:list={['tl-chapter', { alt: i % 2 === 1 }]}>
        <p class="tl-year" aria-hidden="true">{t.year}</p>
        <div class="tl-media">
          {t.hasImage
            ? <img src={`${base}/${t.image}`} alt={`${t.year} — ${t.title}`} loading="lazy" />
            : <div class="tl-placeholder" role="img" aria-label={`${t.title} — 이미지 준비 중`}></div>}
        </div>
        <div class="tl-text">
          <p class="t-meta">{t.year}</p>
          <h2 class="t-lg tl-title">{t.title}</h2>
          <p class="tl-body">{t.body}</p>
        </div>
      </section>
    ))}

    <footer class="tl-outro">
      <p class="t-serif-i">the record continues, minus one.</p>
      <a href={`${base}/archive`} class="t-meta tl-outro-link">browse the archive →</a>
    </footer>
  </div>
</Base>

<style>
  .tl {
    position: relative;
    padding: calc(var(--header-h) + var(--space-4)) var(--gutter) var(--space-5);
  }

  /* 스크롤 진행에 따라 그어지는 세로선 */
  .tl-rule {
    position: absolute;
    top: calc(var(--header-h) + var(--space-4));
    bottom: var(--space-5);
    left: calc(var(--gutter) / 2);
    width: 1px;
    background: var(--line);
    transform: scaleY(0);
    transform-origin: top;
  }

  .tl-head {
    min-height: 40vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
  }

  .tl-sub {
    color: var(--muted);
    font-size: var(--text-lg);
  }

  /* ── 챕터 ── */
  .tl-chapter {
    position: relative;
    min-height: 100svh;
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: var(--space-3);
    align-items: center;
    padding-block: var(--space-4);
  }

  .tl-chapter.alt {
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  }

  .tl-chapter.alt .tl-media {
    order: 2;
  }

  .tl-chapter.alt .tl-text {
    order: 1;
    text-align: right;
    align-items: flex-end;
  }

  /* 거대한 고스트 연도 — 챕터의 배경 타이포 */
  .tl-year {
    position: absolute;
    top: 8%;
    right: -0.02em;
    font-size: clamp(5rem, 14vw, 13rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px var(--faint);
    pointer-events: none;
    user-select: none;
  }

  .tl-chapter.alt .tl-year {
    right: auto;
    left: -0.02em;
  }

  .tl-media {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .tl-media img {
    width: 100%;
    max-height: 72vh;
    object-fit: cover;
    /* 진입 시 GSAP가 밝힘 */
    filter: brightness(0.5) grayscale(0.2);
    transform: scale(1.06);
  }

  .tl-placeholder {
    aspect-ratio: 4 / 3;
    background: radial-gradient(ellipse 90% 70% at 50% 40%, #161614 0%, #0e0e0d 75%);
    border: 1px solid var(--line);
  }

  .tl-text {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: 26rem;
  }

  .tl-chapter.alt .tl-text {
    margin-left: auto;
  }

  .tl-title {
    font-weight: 500;
  }

  .tl-body {
    color: var(--muted);
  }

  :global(html.js) .tl-text > *,
  :global(html.js) .tl-head > * {
    opacity: 0;
    transform: translateY(24px);
  }

  :global(html.js) .tl-year {
    opacity: 0;
  }

  /* ── 아웃트로 ── */
  .tl-outro {
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    text-align: center;
  }

  .tl-outro p {
    font-size: var(--text-lg);
    color: var(--muted);
  }

  .tl-outro-link:hover {
    color: var(--fg);
  }

  /* ── 모바일 ── */
  @media (max-width: 760px) {
    .tl-chapter,
    .tl-chapter.alt {
      grid-template-columns: 1fr;
      align-content: center;
    }

    .tl-chapter.alt .tl-media { order: 1; }
    .tl-chapter.alt .tl-text {
      order: 2;
      text-align: left;
      align-items: flex-start;
      margin-left: 0;
    }

    .tl-year {
      font-size: clamp(4rem, 22vw, 8rem);
    }
  }
</style>

<script is:inline>
  document.documentElement.classList.add('js');
</script>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced) {
    gsap.set(['.tl-head > *', '.tl-text > *', '.tl-year'], { opacity: 1, y: 0 });
    gsap.set('.tl-media img', { filter: 'brightness(1) grayscale(0)', scale: 1 });
    gsap.set('.tl-rule', { scaleY: 1 });
  } else {
    // 헤더 진입
    gsap.to('.tl-head > *', {
      opacity: 1, y: 0, duration: 1.0, stagger: 0.12, ease: 'power3.out', delay: 0.2,
    });

    // 세로선: 페이지 스크롤 진행에 맞춰 그어짐
    gsap.to('.tl-rule', {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: { trigger: '.tl', start: 'top top', end: 'bottom bottom', scrub: 0.4 },
    });

    // 챕터별 연출
    document.querySelectorAll('.tl-chapter').forEach((ch) => {
      const img = ch.querySelector('.tl-media img');

      gsap.to(ch.querySelector('.tl-year'), {
        opacity: 1, duration: 1.4, ease: 'power2.out',
        scrollTrigger: { trigger: ch, start: 'top 65%' },
      });

      gsap.to(ch.querySelectorAll('.tl-text > *'), {
        opacity: 1, y: 0, duration: 1.0, stagger: 0.12, ease: 'power3.out',
        scrollTrigger: { trigger: ch, start: 'top 55%' },
      });

      if (img) {
        gsap.fromTo(img,
          { filter: 'brightness(0.5) grayscale(0.2)', scale: 1.06 },
          {
            filter: 'brightness(1) grayscale(0)', scale: 1, ease: 'none',
            scrollTrigger: { trigger: ch, start: 'top 80%', end: 'center 45%', scrub: 0.5 },
          }
        );
      }
    });
  }
</script>
