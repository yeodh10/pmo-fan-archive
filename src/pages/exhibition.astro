---
import fs from 'node:fs';
import Base from '../layouts/Base.astro';
import exhibitions from '../../data/exhibitions.json';

const entries = exhibitions.map((e) => ({
  ...e,
  hasImage: e.image ? fs.existsSync(new URL(`../../public/${e.image}`, import.meta.url)) : false,
}));
---

<Base title="Exhibition">
  <div class="exh">
    <header class="exh-head">
      <p class="t-meta">exhibition & pop-up</p>
      <h1 class="t-xl">전시 · 팝업</h1>
      <p class="t-serif-i exh-sub">옷을 팔기 전에, 장면을 먼저 만들었다.</p>
    </header>

    <div class="exh-list">
      {entries.map((e) => (
        <section class="exh-item">
          <div class="exh-media">
            {e.hasImage
              ? <img src={`/${e.image}`} alt={`${e.title} — ${e.location}`} loading="lazy" />
              : <div class="exh-placeholder" role="img" aria-label={`${e.title} — 이미지 준비 중`}></div>}
          </div>
          <div class="exh-text">
            <p class="t-meta exh-meta">{e.year} · {e.kind}</p>
            <h2 class="t-lg exh-title">{e.title}</h2>
            <p class="exh-loc">{e.location}</p>
            {e.note && <p class="exh-note t-serif-i">{e.note}</p>}
          </div>
        </section>
      ))}
    </div>

    <footer class="exh-outro">
      <a href="/archive" class="t-meta exh-outro-link">browse the archive →</a>
    </footer>
  </div>
</Base>

<style>
  .exh {
    padding: calc(var(--header-h) + var(--space-4)) var(--gutter) var(--space-5);
    max-width: 1100px;
    margin-inline: auto;
  }

  .exh-head {
    min-height: 32vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .exh-sub {
    color: var(--muted);
    font-size: var(--text-lg);
  }

  .exh-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* 이미지/텍스트 2열, 교차 배치 */
  .exh-item {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
    gap: var(--space-3);
    align-items: center;
  }

  .exh-item:nth-child(even) .exh-media { order: 2; }
  .exh-item:nth-child(even) .exh-text { order: 1; }

  .exh-media {
    overflow: hidden;
  }

  .exh-media img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .exh-placeholder {
    aspect-ratio: 4 / 3;
    background: radial-gradient(ellipse 90% 70% at 50% 40%, #161614 0%, #0e0e0d 75%);
    border: 1px solid var(--line);
  }

  .exh-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .exh-meta {
    color: var(--muted);
  }

  .exh-title {
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .exh-loc {
    color: var(--accent);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
  }

  .exh-note {
    color: var(--muted);
    margin-top: var(--space-1);
  }

  .exh-outro {
    min-height: 30vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .exh-outro-link:hover { color: var(--fg); }

  :global(html.js) .exh-head > *,
  :global(html.js) .exh-item {
    opacity: 0;
    transform: translateY(28px);
  }

  @media (max-width: 760px) {
    .exh-item,
    .exh-item:nth-child(even) .exh-media,
    .exh-item:nth-child(even) .exh-text {
      grid-template-columns: 1fr;
      order: initial;
    }
    .exh-item { gap: var(--space-2); }
  }
</style>

<script is:inline>
  document.documentElement.classList.add('js');
</script>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced) {
    gsap.set(['.exh-head > *', '.exh-item'], { opacity: 1, y: 0 });
  } else {
    gsap.to('.exh-head > *', { opacity: 1, y: 0, duration: 1.0, stagger: 0.12, ease: 'power3.out', delay: 0.15 });
    document.querySelectorAll('.exh-item').forEach((el) => {
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 82%' },
      });
    });
  }
</script>
